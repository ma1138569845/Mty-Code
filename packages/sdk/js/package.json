{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@mty-coder/sdk",
  "version": "0.1.5",
  "description": "TypeScript SDK for the MtyCoder API",
  "keywords": [
    "mty",
    "mtycoder",
    "ai",
    "sdk",
    "coding-assistant"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Xiaomi MtyCoder Team",
  "homepage": "https://mtycoder.example.com/en/mtycoder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matyianyuan/MtyCoder.git",
    "directory": "packages/sdk/js"
  },
  "bugs": {
    "url": "https://github.com/matyianyuan/MtyCoder/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "bun ./script/build.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./v2": "./src/v2/index.ts",
    "./v2/client": "./src/v2/client.ts",
    "./v2/gen/client": "./src/v2/gen/client/index.ts",
    "./v2/server": "./src/v2/server.ts"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.90.10",
    "@tsconfig/node22": "22.0.2",
    "@types/cross-spawn": "6.0.6",
    "@types/node": "22.13.9",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "cross-spawn": "7.0.6"
  }
}
